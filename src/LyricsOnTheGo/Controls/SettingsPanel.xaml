<UserControl x:Class="LyricsOnTheGo.Controls.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LyricsOnTheGo"
             xmlns:c="clr-namespace:LyricsOnTheGo.Controls"
             FontFamily="Segoe UI Variable, Segoe UI"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">

    <UserControl.Resources>
        <local:HexToBrushConverter x:Key="HexToBrush" />

        <!-- Thin overlay scrollbar (matches the original: 6px, rounded white thumb, no buttons). -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="8">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="6" CornerRadius="3" HorizontalAlignment="Center"
                                                        Background="#33FFFFFF" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Lucide-style stroke icon path. -->
        <Style x:Key="IconPath" TargetType="Path">
            <Setter Property="Stroke" Value="White" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Fill" Value="{x:Null}" />
        </Style>

        <!-- Toggle switch (40x22 pill) with an animated thumb slide + track colour crossfade. -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="track" Width="40" Height="22" CornerRadius="11">
                            <Border.Background>
                                <SolidColorBrush x:Name="trackBrush" Color="#2EFFFFFF" />
                            </Border.Background>
                            <Ellipse x:Name="thumb" Width="16" Height="16" Fill="White"
                                     HorizontalAlignment="Left" Margin="3,0,0,0" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="thumbT" X="0" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="thumbT" Storyboard.TargetProperty="X"
                                                             To="18" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="trackBrush" Storyboard.TargetProperty="Color"
                                                            To="#17D346" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="thumbT" Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="trackBrush" Storyboard.TargetProperty="Color"
                                                            To="#2EFFFFFF" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Range slider: thin track, accent round thumb with dark border + accent ring. -->
        <Style x:Key="SettingSlider" TargetType="Slider">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <!-- Click anywhere on the track to jump the thumb there AND keep dragging from that
                 point if the button stays held (handled in OnSliderTrackPress). -->
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnSliderTrackPress" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="#29FFFFFF" />
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16" FocusVisualStyle="{x:Null}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <!-- 1px accent ring → 2px dark border → solid accent fill. -->
                                                    <Ellipse Fill="#0B0B0B" />
                                                    <Ellipse Margin="2" Fill="#17D346" />
                                                    <Ellipse Stroke="#17D346" StrokeThickness="1" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#17D346" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="Margin" Value="0,18,0,10" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#17D346" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#73FFFFFF" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="HexBox" TargetType="TextBox">
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="74" />
            <Setter Property="Height" Value="26" />
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="CharacterCasing" Value="Upper" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmented icon button (alignment). -->
        <Style x:Key="SegBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#8CFFFFFF" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="7">
                            <Border.Background>
                                <SolidColorBrush x:Name="segBrush" Color="Transparent" />
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D9FFFFFF" />
                            </Trigger>
                            <Trigger Property="Tag" Value="selected">
                                <Setter Property="Foreground" Value="#000000" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="segBrush" Storyboard.TargetProperty="Color"
                                                            To="#17D346" Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="segBrush" Storyboard.TargetProperty="Color"
                                                            To="Transparent" Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Text segmented button (EN / ES). -->
        <Style x:Key="LangBtn" TargetType="Button" BasedOn="{StaticResource SegBtn}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="22" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <!-- Reset / clear-cache style button. -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="#0DFFFFFF" BorderBrush="#29FFFFFF" BorderThickness="1"
                                CornerRadius="9" Padding="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1FFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header close (x) chrome button. -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1" />
                                <Setter TargetName="b" Property="Background" Value="#1FFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#0B0B0B" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header (also drags the window) -->
            <Grid Grid.Row="0" Margin="16,13,10,11" Background="#01000000" Cursor="SizeAll"
                  MouseLeftButtonDown="OnHeaderDrag">
                <Border Height="1" VerticalAlignment="Bottom" Background="#14FFFFFF" Margin="-16,0,-10,-11" />
                <TextBlock x:Name="TitleText" Text="Settings" Foreground="White"
                           FontSize="13" FontWeight="Bold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#12FFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1"
                            CornerRadius="9" Padding="2" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="LangEnBtn" Content="EN" Style="{StaticResource LangBtn}" Click="OnLangEn" />
                            <Button x:Name="LangEsBtn" Content="ES" Style="{StaticResource LangBtn}" Click="OnLangEs" />
                        </StackPanel>
                    </Border>
                    <Button x:Name="CloseBtn" Style="{StaticResource ChromeBtn}" Click="OnClose">
                        <Viewbox Width="16" Height="16">
                            <Canvas Width="24" Height="24">
                                <Path Style="{StaticResource IconPath}" Data="M18 6 6 18 M6 6 18 18" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,0,16,18">
                <StackPanel>
                    <!-- APPEARANCE -->
                    <TextBlock x:Name="HdrAppearance" Text="APPEARANCE" Style="{StaticResource GroupTitle}" Margin="0,14,0,10" />

                    <Grid Margin="0,6">
                        <TextBlock x:Name="LblTextColor" Text="Text color" Style="{StaticResource FieldLabel}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBox Style="{StaticResource HexBox}"
                                     Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}" />
                            <Button x:Name="TextSwatch" Width="30" Height="26" Margin="8,0,0,0" Cursor="Hand" Click="OnPickTextColor">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="7" BorderBrush="#2EFFFFFF" BorderThickness="1"
                                                Background="{Binding TextColor, Converter={StaticResource HexToBrush}}" />
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,6">
                        <TextBlock x:Name="LblBgColor" Text="Background color" Style="{StaticResource FieldLabel}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBox Style="{StaticResource HexBox}"
                                     Text="{Binding BgColor, UpdateSourceTrigger=PropertyChanged}" />
                            <Button x:Name="BgSwatch" Width="30" Height="26" Margin="8,0,0,0" Cursor="Hand" Click="OnPickBgColor">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="7" BorderBrush="#2EFFFFFF" BorderThickness="1"
                                                Background="{Binding BgColor, Converter={StaticResource HexToBrush}}" />
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <TextBlock x:Name="LblBgOpacity" Text="Background opacity" Style="{StaticResource FieldLabel}" />
                        <TextBlock Text="{Binding BgOpacity, StringFormat={}{0}%}" Style="{StaticResource ValueLabel}" />
                    </Grid>
                    <Slider Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" Margin="0,6,0,0" Value="{Binding BgOpacity}" />
                    <TextBlock x:Name="HintBgOpacity" Text="Lower opacity = more glass effect (background blur)." Style="{StaticResource Hint}" />

                    <Grid Margin="0,14,0,0">
                        <TextBlock x:Name="LblTextSize" Text="Text size" Style="{StaticResource FieldLabel}" />
                        <TextBlock Text="{Binding FontSize}" Style="{StaticResource ValueLabel}" />
                    </Grid>
                    <Slider Style="{StaticResource SettingSlider}" Minimum="14" Maximum="72" Margin="0,6,0,0" Value="{Binding FontSize}" />

                    <Grid Margin="0,14,0,0">
                        <TextBlock x:Name="LblDim" Text="Dim inactive lines" Style="{StaticResource FieldLabel}" />
                        <TextBlock Text="{Binding Dim, StringFormat={}{0}%}" Style="{StaticResource ValueLabel}" />
                    </Grid>
                    <Slider Style="{StaticResource SettingSlider}" Minimum="10" Maximum="90" TickFrequency="5"
                            IsSnapToTickEnabled="True" Margin="0,6,0,0" Value="{Binding Dim}" />

                    <Grid Margin="0,14,0,0">
                        <TextBlock x:Name="LblAlignment" Text="Alignment" Style="{StaticResource FieldLabel}" />
                        <Border HorizontalAlignment="Right" Background="#12FFFFFF" BorderBrush="#1AFFFFFF"
                                BorderThickness="1" CornerRadius="9" Padding="2">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="AlignLeftBtn" Style="{StaticResource SegBtn}" Click="OnAlignLeft">
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource IconPath}"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Data="M15 12H3 M17 18H3 M21 6H3" />
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button x:Name="AlignCenterBtn" Style="{StaticResource SegBtn}" Click="OnAlignCenter">
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource IconPath}"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Data="M17 12H7 M19 18H5 M21 6H3" />
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- SYNC -->
                    <TextBlock x:Name="HdrSync" Text="SYNC" Style="{StaticResource GroupTitle}" />
                    <Grid>
                        <TextBlock x:Name="LblOffset" Text="Lyrics offset" Style="{StaticResource FieldLabel}" />
                        <TextBlock x:Name="OffsetValue" Style="{StaticResource ValueLabel}" />
                    </Grid>
                    <Slider x:Name="OffsetSlider" Style="{StaticResource SettingSlider}" Minimum="-6000" Maximum="6000"
                            TickFrequency="50" IsSnapToTickEnabled="True" Margin="0,6,0,0" Value="{Binding Offset}" />
                    <TextBlock x:Name="HintOffset"
                               Text="Delays (+) or advances (−) the active line up to ±6 s. Useful if the lyrics are out of sync."
                               Style="{StaticResource Hint}" />

                    <!-- VISIBILITY -->
                    <TextBlock x:Name="HdrVisibility" Text="VISIBILITY" Style="{StaticResource GroupTitle}" />
                    <Grid Margin="0,4">
                        <TextBlock x:Name="LblAutohide" Text="Auto-hide header" Style="{StaticResource FieldLabel}" />
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding AutoHideHeader}" />
                    </Grid>
                    <TextBlock x:Name="HintAutohide"
                               Text="Hides the top bar. Move the mouse or click the overlay to show it for 2 s and open settings."
                               Style="{StaticResource Hint}" />
                    <Grid Margin="0,10,0,0">
                        <TextBlock x:Name="LblShowProgress" Text="Show progress bar" Style="{StaticResource FieldLabel}" />
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding ShowProgress}" />
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <TextBlock x:Name="LblShowTimes" Text="Show times (current / total)" Style="{StaticResource FieldLabel}" />
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding ShowTimes}" />
                    </Grid>

                    <!-- BEHAVIOR -->
                    <TextBlock x:Name="HdrBehavior" Text="BEHAVIOR" Style="{StaticResource GroupTitle}" />
                    <Grid Margin="0,4">
                        <TextBlock x:Name="LblAutostart" Text="Start with Windows" Style="{StaticResource FieldLabel}" />
                        <CheckBox x:Name="AutostartToggle" Style="{StaticResource ToggleSwitch}"
                                  HorizontalAlignment="Right" Click="OnAutostartToggle" />
                    </Grid>
                    <TextBlock x:Name="HintAutostart" Text="Launches the overlay automatically when you sign in to Windows."
                               Style="{StaticResource Hint}" />
                    <Grid Margin="0,10,0,0">
                        <TextBlock x:Name="LblClickthrough" Text="Click-through (ignore clicks)" Style="{StaticResource FieldLabel}" />
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding ClickThrough}" />
                    </Grid>
                    <TextBlock x:Name="HintClickthrough"
                               Text="This lets the overlay pass clicks through. To disable it, use the tray icon menu."
                               Style="{StaticResource Hint}" />
                    <Grid Margin="0,10,0,0">
                        <TextBlock x:Name="LblPlainFallback" Text="Show plain text if no sync" Style="{StaticResource FieldLabel}" />
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding PlainFallback}" />
                    </Grid>

                    <!-- CACHE -->
                    <TextBlock x:Name="HdrCache" Text="LYRICS CACHE" Style="{StaticResource GroupTitle}" />
                    <TextBlock x:Name="HintCache"
                               Text="Lyrics are saved to disk so they aren't downloaded again. Clear the cache to force a fresh download."
                               Style="{StaticResource Hint}" Margin="0,0,0,10" />
                    <Button x:Name="ClearCacheBtn" Style="{StaticResource ActionBtn}" Click="OnClearCache">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Path Style="{StaticResource IconPath}"
                                          Data="M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="ClearCacheLabel" Text="Clear lyrics cache" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ClearOffsetsBtn" Style="{StaticResource ActionBtn}" Click="OnClearOffsets" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Path Style="{StaticResource IconPath}"
                                          Data="M2 12 A10 10 0 1 0 22 12 A10 10 0 1 0 2 12 Z M12 7 V12 L16 14" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="ClearOffsetsLabel" Text="Clear saved offsets" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="CacheStatus" Style="{StaticResource Hint}" Margin="0,6,0,0"
                               Visibility="Collapsed" />

                    <!-- LOCAL DATABASE -->
                    <TextBlock x:Name="HdrLocalDb" Text="LOCAL DATABASE" Style="{StaticResource GroupTitle}" />
                    <TextBlock x:Name="HintLocalDb"
                               Text="Link the offline LRCLIB database for instant, offline lookups."
                               Style="{StaticResource Hint}" Margin="0,0,0,4" />
                    <TextBlock Margin="0,0,0,4">
                        <Hyperlink x:Name="DbDumpsLink" Click="OnDbDumps" Foreground="#17D346" TextDecorations="None">
                            <Run x:Name="DbDumpsText" Text="Download the database ↗" FontSize="11.5" />
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock x:Name="WarnLocalDb" Text="The uncompressed database is around 117 GB."
                               Style="{StaticResource Hint}" Foreground="#E8A33C" Margin="0,0,0,8" />
                    <Border Background="#12FFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="7"
                            Padding="9,7" Margin="0,0,0,8">
                        <TextBlock x:Name="LocalDbPathText" Foreground="#B0FFFFFF" FontFamily="Cascadia Code, Consolas"
                                   FontSize="11" TextWrapping="Wrap" Text="(none)" />
                    </Border>
                    <Button x:Name="SelectDbBtn" Style="{StaticResource ActionBtn}" Click="OnSelectDb">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Path Style="{StaticResource IconPath}"
                                          Data="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="SelectDbLabel" Text="Select database file…" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="UnlinkDbBtn" Style="{StaticResource ActionBtn}" Click="OnUnlinkDb" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Path Style="{StaticResource IconPath}" Data="M18 6 6 18 M6 6l12 12" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="UnlinkDbLabel" Text="Unlink database" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="LocalDbStatus" Style="{StaticResource Hint}" Margin="0,6,0,0" />

                    <!-- RESET -->
                    <Button x:Name="ResetBtn" Style="{StaticResource ActionBtn}" Click="OnReset" Margin="0,18,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Path Style="{StaticResource IconPath}"
                                          Data="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8 M3 3v5h5" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="ResetLabel" Text="Reset" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Footer -->
                    <Border Margin="0,14,0,0" Padding="0,14,0,2" BorderBrush="#14FFFFFF" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <!-- GitHub -->
                            <TextBlock HorizontalAlignment="Center">
                                <Hyperlink x:Name="GitHubLink" Click="OnGitHub" Foreground="#8CFFFFFF" TextDecorations="None">
                                    <InlineUIContainer BaselineAlignment="Center">
                                        <Viewbox Width="13" Height="13" Margin="0,0,5,-1">
                                            <Canvas Width="24" Height="24">
                                                <Path Stroke="#8CFFFFFF" StrokeThickness="2" StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="{x:Null}"
                                                      Data="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                                            </Canvas>
                                        </Viewbox>
                                    </InlineUIContainer><Run>github.com/The-MuffinDev</Run>
                                </Hyperlink>
                            </TextBlock>

                            <!-- Buy me a coffee -->
                            <Button x:Name="CoffeeBtn" Click="OnBuyMeCoffee" Cursor="Hand"
                                    HorizontalAlignment="Center" Margin="0,13,0,0"
                                    ToolTip="buymeacoffee.com/TheMuffinDev">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CoffeeBg" Background="#FFDD00" CornerRadius="8" Padding="16,9">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CoffeeBg" Property="Background" Value="#FFE838" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="CoffeeBg" Property="Background" Value="#E6C700" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="17" Height="17" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Stroke="#000000" StrokeThickness="2" StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="{x:Null}"
                                                  Data="M6 2v2 M10 2v2 M14 2v2 M18 8h1a4 4 0 0 1 0 8h-1 M3 8h15v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock x:Name="CoffeeLabel" Text="Buy me a coffee"
                                               Foreground="#000000" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- App version -->
                            <TextBlock x:Name="VersionText" HorizontalAlignment="Center" Foreground="#5AFFFFFF"
                                       FontSize="10.5" Margin="0,13,0,0" Text="LyricsOnTheGo v1.2.1" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Inline colour picker (no separate OS dialog). -->
            <Popup x:Name="ColorPopup" StaysOpen="False" AllowsTransparency="True"
                   Placement="Left" PopupAnimation="Fade">
                <c:ColorPicker x:Name="Picker" />
            </Popup>
        </Grid>
    </Border>
</UserControl>
